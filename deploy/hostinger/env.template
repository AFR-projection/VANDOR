# Salin ke /var/www/vandor/.env.local lalu edit semua nilai.
# Generate AUTH_SECRET: openssl rand -base64 32

AUTH_SECRET=
POSTGRES_URL=postgresql://...@neon.tech/neondb?sslmode=require

VANDOR_NUMPAD_PIN=1234
VANDOR_OWNER_EMAIL=owner@example.com
VANDOR_OWNER_PASSWORD=ganti-password-kuat

# Production HTTPS (disarankan):
# NEXT_PUBLIC_APP_URL=https://vandor.dataku.id
# OPENROUTER_APP_URL=https://vandor.dataku.id
#
# Sementara belum SSL (http://IP):
NEXT_PUBLIC_APP_URL=http://72.61.114.56
OPENROUTER_APP_URL=http://72.61.114.56

# Paksa matikan BotID (opsional; http://IP sudah otomatis off)
# NEXT_PUBLIC_VANDOR_DISABLE_BOTID=1

VANDOR_GATE_TTL_SECONDS=2592000
VANDOR_DISABLE_MESSAGE_LIMIT=true

# Opsional — bisa juga lewat Pengaturan UI (terenkripsi)
OPENROUTER_API_KEY=
TAVILY_API_KEY=

# Cloudflare R2 (berangkas + upload) — wajib disarankan production
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=

# WhatsApp — di VPS tidak perlu bridge; scan QR dari Pengaturan
WHATSAPP_OWNER_NUMBERS=

# YouTube di VPS — tidak didukung (Google blokir IP datacenter)
# TikTok/IG: yt-dlp otomatis — bash deploy/hostinger/install-ytdlp.sh

# Cobalt opsional (Vercel / fallback). Jangan pakai api.cobalt.tools publik tanpa JWT.
# COBALT_API_URL=
# COBALT_API_KEY=
# COBALT_ALLOW_PUBLIC=0

# === VANDOR Autonomous — otak otonom 24/7 (PM2: vandor-agent) ===
# Aktifkan worker (set false untuk mematikan total tanpa hapus PM2)
VANDOR_AGENT_ENABLED=true
# Jeda antar siklus OODA (ms). Default 30000 (30 detik).
VANDOR_AGENT_TICK_MS=30000
# Maks. task per tick (cegah overload)
VANDOR_AGENT_MAX_TASKS=3
# Log detail observasi tiap tick
VANDOR_AGENT_DEBUG=false

# Secret bersama worker<->web untuk notifikasi internal (WAJIB untuk WA alert)
# Generate: openssl rand -hex 24
VANDOR_AGENT_INTERNAL_SECRET=
# URL app internal (default sudah benar untuk 1 VPS)
VANDOR_INTERNAL_API_URL=http://127.0.0.1:3000

# Model reasoning worker (default model gratis tools-capable)
# VANDOR_AGENT_MODEL=meta-llama/llama-3.3-70b-instruct:free

# Service & target yang dipantau (CSV). Sesuaikan dengan VPS-mu.
VANDOR_AGENT_SERVICES=nginx,redis-server
VANDOR_AGENT_PM2=vandor
VANDOR_AGENT_UPTIME=http://127.0.0.1:3000/ping
VANDOR_AGENT_LOGS=/var/log/vandor-error.log,/var/log/vandor-agent-error.log

# Ambang batas alert (persen) — opsional, default sudah wajar
# VANDOR_AGENT_CPU_WARN=85
# VANDOR_AGENT_MEM_WARN=85
# VANDOR_AGENT_DISK_WARN=85
