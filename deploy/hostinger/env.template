# Salin ke /var/www/vandor/.env.local lalu edit semua nilai.
# Generate AUTH_SECRET: openssl rand -base64 32

AUTH_SECRET=
POSTGRES_URL=postgresql://...@neon.tech/neondb?sslmode=require

VANDOR_NUMPAD_PIN=1234
VANDOR_OWNER_EMAIL=owner@example.com
VANDOR_OWNER_PASSWORD=ganti-password-kuat

# Ganti dengan domain atau http://IP-VPS (contoh http://72.61.114.56)
NEXT_PUBLIC_APP_URL=http://72.61.114.56
OPENROUTER_APP_URL=http://72.61.114.56

VANDOR_GATE_TTL_SECONDS=2592000
VANDOR_DISABLE_MESSAGE_LIMIT=true

# Opsional — bisa juga lewat Pengaturan UI (terenkripsi)
OPENROUTER_API_KEY=
TAVILY_API_KEY=

# Cloudflare R2 (berangkas + upload) — wajib disarankan production
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=

# WhatsApp — di VPS tidak perlu bridge; scan QR dari Pengaturan
WHATSAPP_OWNER_NUMBERS=

# Unduh media YouTube/TikTok — yt-dlp sudah dipasang setup-server.sh
# YT_DLP_PATH=yt-dlp

# Cobalt opsional (fallback remote)
# COBALT_API_URL=
# COBALT_API_KEY=
