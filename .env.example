# Auth — generate: openssl rand -base64 32
AUTH_SECRET=****

# Neon Postgres
POSTGRES_URL=postgresql://user:password@ep-xxx.neon.tech/neondb?sslmode=require

# OpenRouter
OPENROUTER_API_KEY=sk-or-v1-****
OPENROUTER_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ——— VANDOR: akses pribadi (wajib) ———
# PIN numpad WAJIB 4 digit angka (hanya kamu yang tahu)
# 3x salah -> IP diblokir 1 jam
VANDOR_NUMPAD_PIN=1234

# Satu akun owner — orang lain tidak bisa daftar
VANDOR_OWNER_EMAIL=boss@vandor.local
VANDOR_OWNER_PASSWORD=your-strong-password-here

# Sesi gate per IP (detik). Default 3600 = 1 jam
VANDOR_GATE_TTL_SECONDS=3600

# Nama tampilan di sidebar (opsional)
NEXT_PUBLIC_VANDOR_OWNER_NAME=Boss

# Model embedding memory
MEMORY_EMBEDDING_MODEL=openai/text-embedding-3-small

# Limit pesan per jam (default 10000 untuk user regular). Nonaktifkan total:
VANDOR_DISABLE_MESSAGE_LIMIT=true
# VANDOR_MAX_MESSAGES_PER_HOUR=10000

# File uploads & PDF/DOCX export (WAJIB di Vercel — tanpa ini generate PDF gagal)
# Vercel Dashboard → Storage → Blob → BLOB_READ_WRITE_TOKEN
# BLOB_READ_WRITE_TOKEN=vercel_blob_rw_****

# Cloudflare R2 (alternatif Blob — S3-compatible, murah untuk file besar)
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET_NAME=vandor-files
# R2_PUBLIC_URL=https://pub-xxxx.r2.dev

# Web search (opsional). Tanpa key, fallback DuckDuckGo + Wikipedia.
# Daftar gratis 1000 query/bulan di https://tavily.com
# TAVILY_API_KEY=tvly-xxxxx

# Cuaca real-time (OpenWeatherMap — gratis tier)
# Daftar: https://home.openweathermap.org/api_keys
# Weather Maps 1.0 (tile temp/hujan/awan): ikut API key standar — dok /api/weathermaps
# Weather Maps 2.0 (/maps/2.0/weather): butuh langganan terpisah di dashboard OWM
# OPENWEATHERMAP_API_KEY=your_openweather_api_key

# Model khusus sintesis jawaban web search (opsional, default = model chat aktif)
# Contoh: anthropic/claude-sonnet-4, google/gemini-2.5-flash-preview, deepseek/deepseek-chat-v3-0324
# VANDOR_WEB_SEARCH_MODEL=anthropic/claude-sonnet-4

# Smart model router (hanya override saat model free dipilih di UI)
# VANDOR_MODEL_SIMPLE=meta-llama/llama-3.3-70b-instruct:free
# VANDOR_MODEL_REASONING=deepseek/deepseek-chat-v3-0324
# VANDOR_MODEL_CODING=deepseek/deepseek-chat-v3-0324
# VANDOR_MODEL_RESEARCH=google/gemini-2.0-flash-exp:free

# Conversation summarization interval (messages per summary). Default 15.
# VANDOR_SUMMARY_INTERVAL=15

# Disable response polish step (1 = off)
# VANDOR_DISABLE_POLISH=1

# Disable AI response cache (1 = off)
# VANDOR_DISABLE_RESPONSE_CACHE=1

# Setelah deploy: jalankan npm run db:migrate (tabel ToolEvent untuk log aktivitas tool)

# ——— Unduh media (/tt /ytv /yts /ig) ———
# Wajib agar user dapat link unduhan (sama seperti PDF):
# BLOB_READ_WRITE_TOKEN=vercel_blob_rw_****
#
# Lokal (Windows): pasang yt-dlp di PATH — tidak perlu env engine
#   winget install yt-dlp
#
# Vercel (serverless): yt-dlp biasanya tidak jalan → pakai instance Cobalt sendiri:
# WAJIB pakai https:// (tanpa https Node fetch gagal: "Failed to parse URL")
# COBALT_API_URL=https://cobalt-api-production-2f6c.up.railway.app
# COBALT_API_KEY=                           # jika instance pakai auth
# YT_DLP_PATH=C:\path\to\yt-dlp.exe          # opsional jika tidak di PATH
# COBALT_ALLOW_PUBLIC=1                      # uji saja — jangan production
# VANDOR_PREFER_YTDLP=1                      # paksa yt-dlp dulu meski Cobalt ada (dev)
#
# TikTok (/tt): di Vercel otomatis pakai TikWM API (bukan Cobalt — IP cloud diblokir TikTok).
# YouTube (/ytv /yts): di Vercel otomatis pakai InnerTube (ANDROID_VR) → Cobalt → Piped/Invidious.
# PIPED_API_URL=https://pipedapi.kavin.rocks          # opsional, default sudah ada
# INVIDIOUS_INSTANCE_URL=https://yewtu.be             # opsional fallback
# VANDOR_DISABLE_TIKWM=1  # paksa hanya Cobalt/yt-dlp untuk TikTok
# TikTok/IG sering gagal di Cobalt cloud (error.api.fetch.fail) — di PC lokal:
#   winget install yt-dlp
# lalu COBALT_API_URL opsional; unduhan akan pakai yt-dlp otomatis.
